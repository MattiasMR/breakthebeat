---
import { ArrowUpRight } from "@lucide/astro";
import { event, footerGroups } from "../data/site";
---

<footer class="site-footer">
  <div class="footer-top">
    <a class="footer-logo" href="/" aria-label="Break The Beat inicio">
      <img src="/assets/break-the-beat-logo.webp" width="900" height="569" alt="Break The Beat" />
    </a>
    <a class="footer-more" href="#inicio">
      Ver mas
      <ArrowUpRight size={17} aria-hidden="true" />
    </a>
  </div>
  <div class="footer-grid">
    {footerGroups.map((group) => (
      <nav class="footer-group" aria-label={group.title}>
        <h2>{group.title}</h2>
        {group.links.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noreferrer" : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>
    ))}
    <div class="footer-meta">
      <p>© 2026 {event.title}</p>
      <p>{event.city}</p>
      <p>{event.instagram}</p>
    </div>
  </div>
</footer>
